datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id           String        @id @default(cuid())
  name         String
  ownerId      String?
  createdAt    DateTime      @default(now())
  memberships  Membership[]
  boards       Board[]
  apiTokens    ApiToken[]
  wikiSections WikiSection[]
}

model Membership {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  color     String   @default("#64748b")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String
  createdAt    DateTime     @default(now())
  memberships  Membership[]
}

model ApiToken {
  id         String    @id @default(cuid())
  projectId  String
  name       String
  tokenHash  String    @unique
  scopes     String[]
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Board {
  id        String   @id @default(cuid())
  projectId String
  name      String
  seq       Int
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns   Column[]
  cards     Card[]

  @@unique([projectId, seq])
}

model Column {
  id      String @id @default(cuid())
  boardId String
  title   String
  order   Int
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   Card[]
}

model Card {
  id           String       @id @default(cuid())
  boardId      String
  columnId     String
  number       Int
  title        String
  body         String?
  priority     String?
  authorType   String       @default("user")
  authorId     String?
  assigneeType String?
  assigneeId   String?
  order        Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  board        Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column       Column       @relation(fields: [columnId], references: [id], onDelete: Restrict)
  comments     Comment[]
  activities   Activity[]
  attachments  Attachment[]

  @@unique([boardId, number])
}

model Comment {
  id         String   @id @default(cuid())
  cardId     String
  authorType String   @default("user")
  authorId   String?
  body       String
  createdAt  DateTime @default(now())
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(cuid())
  cardId    String
  actorType String   // 'user' | 'agent'
  actorId   String
  action    String   // 'create' | 'update' | 'move' | 'comment'
  before    Json?
  after     Json?
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(cuid())
  cardId    String
  key       String   // S3 object key
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model WikiSection {
  id        String     @id @default(cuid())
  projectId String
  title     String
  order     Int
  createdAt DateTime   @default(now())
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pages     WikiPage[]
}

model WikiPage {
  id         String      @id @default(cuid())
  sectionId  String
  title      String
  body       String      @default("") // markdown
  order      Int         @default(0)
  authorType String      @default("user") // 'user' | 'agent'
  authorId   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  section    WikiSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}
