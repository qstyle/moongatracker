datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id           String        @id @default(cuid())
  name         String
  ownerId      String?
  createdAt    DateTime      @default(now())
  memberships  Membership[]
  boards       Board[]
  apiTokens    ApiToken[]
  wikiSections WikiSection[]
  canvas       Canvas?
}

model Membership {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  color     String   @default("#64748b")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  passwordHash      String
  createdAt         DateTime           @default(now())
  memberships       Membership[]
  apiTokens         ApiToken[]
  telegramLink      TelegramLink?
  telegramLinkCodes TelegramLinkCode[]
  notificationPrefs NotificationPreferences?
}

// Per-user toggles for which notifications to deliver. One row per user; an
// absent row means "everything on" (defaults), so existing users keep receiving
// notifications without a backfill. Channel-agnostic — currently gates Telegram.
model NotificationPreferences {
  id                  String   @id @default(cuid())
  userId              String   @unique
  cardMoved           Boolean  @default(true)
  cardAssigned        Boolean  @default(true)
  cardCommented       Boolean  @default(true)
  cardAssignedToAgent Boolean  @default(true)
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Links a user's account to a Telegram chat so the bot can DM them about
// movements of "their" cards (authored / assigned). One TG chat per user.
// chatId is stored as String (not BigInt) — the schema has no other BigInt and
// bigint is not JSON-serializable; grammy's numeric chat.id is stringified.
model TelegramLink {
  id        String   @id @default(cuid())
  userId    String   @unique
  chatId    String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Short-lived one-time code for the deep-link onboarding
// (t.me/<bot>?start=<code>). Consumed by the bot's /start handler.
model TelegramLinkCode {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiToken {
  id         String    @id @default(cuid())
  // Owner of the token. Auth is anchored here: the token grants access to all
  // of this user's projects (via Membership). Nullable only for legacy tokens.
  userId     String?
  // Kept for history / legacy single-project tokens; no longer the auth anchor.
  projectId  String?
  name       String
  tokenHash  String    @unique
  scopes     String[]
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Board {
  id        String   @id @default(cuid())
  projectId String
  name      String
  seq       Int
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns   Column[]
  cards     Card[]

  @@unique([projectId, seq])
}

model Column {
  id      String @id @default(cuid())
  boardId String
  title   String
  order   Int
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   Card[]
}

model Card {
  id           String       @id @default(cuid())
  boardId      String
  columnId     String
  number       Int
  title        String
  body         String?
  priority     String?
  authorType   String       @default("user")
  authorId     String?
  assigneeType String?
  assigneeId   String?
  order        Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  board        Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column       Column       @relation(fields: [columnId], references: [id], onDelete: Restrict)
  comments     Comment[]
  activities   Activity[]
  attachments  Attachment[]

  @@unique([boardId, number])
}

model Comment {
  id         String   @id @default(cuid())
  cardId     String
  authorType String   @default("user")
  authorId   String?
  body       String
  createdAt  DateTime @default(now())
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(cuid())
  cardId    String
  actorType String   // 'user' | 'agent'
  actorId   String
  action    String   // 'create' | 'update' | 'move' | 'comment'
  before    Json?
  after     Json?
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(cuid())
  cardId    String
  key       String   // S3 object key
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model WikiSection {
  id        String     @id @default(cuid())
  projectId String
  title     String
  order     Int
  createdAt DateTime   @default(now())
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pages     WikiPage[]
}

model WikiPage {
  id         String      @id @default(cuid())
  sectionId  String
  title      String
  body       String      @default("") // markdown
  order      Int         @default(0)
  authorType String      @default("user") // 'user' | 'agent'
  authorId   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  section    WikiSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

// Весь холст проекта — один JSON-документ (как пример React Flow save/restore).
// data = { nodes: RFNode[], edges: RFEdge[], viewport?: { x, y, zoom } }.
// Связь ноды с карточкой хранится внутри node.data.cardId (резолвится на чтении).
model Canvas {
  projectId String   @id
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
