datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("member")
  createdAt    DateTime @default(now())
}

model Board {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  columns   Column[]
  cards     Card[]
  labels    Label[]
}

model Column {
  id      String @id @default(cuid())
  boardId String
  key     String
  title   String
  order   Int
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, key])
}

model Card {
  id         String      @id @default(cuid())
  boardId    String
  columnKey  String
  title      String
  body       String?
  priority   Int         @default(0)
  order      Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  board      Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  comments   Comment[]
  labels     CardLabel[]
}

model Comment {
  id         String   @id @default(cuid())
  cardId     String
  authorType String   @default("human") // human | agent
  authorId   String?
  body       String
  createdAt  DateTime @default(now())
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Label {
  id      String      @id @default(cuid())
  boardId String
  name    String
  color   String
  board   Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   CardLabel[]
}

model CardLabel {
  cardId  String
  labelId String
  card    Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  scope      String[]
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
}
