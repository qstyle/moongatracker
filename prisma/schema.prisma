datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("member")
  createdAt    DateTime @default(now())
}

model Board {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  columns   Column[]
  cards     Card[]
}

model Column {
  id      String @id @default(cuid())
  boardId String
  key     String
  title   String
  order   Int
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, key])
}

model Card {
  id         String   @id @default(cuid())
  boardId    String
  columnKey  String
  title      String
  body       String?
  priority   Int      @default(0)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  board      Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
}
